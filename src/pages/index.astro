---
import BlogLayout from "../layouts/BlogLayout.astro";
import { getBlogPosts } from "../lib/blog-data";

const posts = getBlogPosts();
---

<BlogLayout title="Sane Coding Blog" description="Sane Coding Blog by Stefano Cristiano" posts={posts}>
  <section class="blog-intro">
    <h1>Sane Coding Blog</h1>
    <p>
      Release notes, design notes, and practical updates around Sane C++ Libraries.
    </p>
    <a class="button primary" href="/SaneCppLibraries/">Open Sane C++ Libraries</a>
  </section>

  <section class="post-feed" aria-label="Blog posts">
    {posts.map((post) => (
      <article class="blog-card">
        <header>
          <h2><a href={`/site/blog/${post.slug}.html`}>{post.title}</a></h2>
          <time datetime={post.date}>{post.date}</time>
        </header>
        {post.image && (
          <a class="blog-card-media" href={`/site/blog/${post.slug}.html`} aria-label={post.title}>
            <img src={post.image} alt="" loading="lazy" />
          </a>
        )}
        <p>{post.summary}</p>
        <a class="continue-link" href={`/site/blog/${post.slug}.html`}>Continue...</a>
      </article>
    ))}
  </section>
</BlogLayout>

<style>
  .blog-intro {
    margin-bottom: 1.5rem;
    padding: 0.4rem 0 1.4rem;
  }

  .blog-intro h1 {
    margin: 0 0 0.6rem;
    font-size: clamp(2.4rem, 6vw, 3.7rem);
    line-height: 1;
  }

  .blog-intro p {
    margin: 0 0 1.25rem;
    max-width: 40rem;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.65;
  }

  .post-feed {
    display: grid;
    gap: 2rem;
    min-width: 0;
  }

  .blog-card {
    min-width: 0;
    padding: clamp(1.25rem, 3vw, 2.1rem);
    border-radius: 8px;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-card) 96%, white 2%);
    box-shadow: var(--shadow);
  }

  .blog-card header {
    margin-bottom: 1.05rem;
  }

  .blog-card h2 {
    margin: 0 0 0.55rem;
    color: var(--text);
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.04;
    overflow-wrap: anywhere;
  }

  .blog-card time {
    color: color-mix(in srgb, var(--accent-cool) 70%, var(--muted));
    font-size: 0.82rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .blog-card-media {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-width: 0;
    aspect-ratio: 2.45 / 1;
    margin: 0.6rem 0 1.25rem;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--border-strong);
    background: var(--surface-strong);
  }

  .blog-card-media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .blog-card p {
    margin: 0;
    color: var(--muted-strong);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .continue-link {
    display: inline-flex;
    margin-top: 1.25rem;
    color: var(--link);
    font-weight: 750;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  @media (max-width: 720px) {
    .blog-intro {
      padding-top: 0;
    }

    .blog-card {
      padding: 1rem;
    }

    .blog-card h2 {
      font-size: clamp(1.55rem, 8vw, 2.2rem);
    }

    .blog-card-media {
      aspect-ratio: 2.45 / 1;
    }
  }
</style>
