---
import BlogLayout from "../../../layouts/BlogLayout.astro";
import { getBlogPosts } from "../../../lib/blog-data";

export function getStaticPaths() {
  const posts = getBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const posts = getBlogPosts();
---

<BlogLayout title={post.title} description={post.summary} posts={posts} activeSlug={post.slug} toc={post.toc}>
  <article class="blog-post">
    <header id="section-0">
      <time datetime={post.date}>{post.date}</time>
      <h1>{post.title}</h1>
      {post.image && (
        <figure class="post-hero-image">
          <img src={post.image} alt="" loading="eager" />
        </figure>
      )}
      {post.summary && <p>{post.summary}</p>}
    </header>
    <div class="prose blog-prose" set:html={post.html} />
  </article>
</BlogLayout>

<style>
  .blog-post {
    min-width: 0;
  }

  .blog-post header {
    margin-bottom: 2rem;
  }

  time {
    display: block;
    margin-bottom: 0.65rem;
    color: color-mix(in srgb, var(--accent-cool) 70%, var(--muted));
    font-size: 0.82rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 1.2rem;
    color: var(--text);
    font-size: clamp(2.7rem, 7vw, 4.6rem);
    line-height: 1;
  }

  header p {
    margin: 1.4rem 0 0;
    color: var(--muted-strong);
    font-size: 1.16rem;
    line-height: 1.75;
  }

  .post-hero-image {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 2.45 / 1;
    margin: 0;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--border-strong);
    background: var(--surface-strong);
  }

  .post-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .blog-prose {
    color: var(--muted-strong);
  }

  .blog-prose :global(img) {
    max-height: 72vh;
    object-fit: contain;
    border-radius: 8px;
    margin: 1.5rem auto;
  }

  .blog-prose :global(a) {
    color: var(--link);
  }

  .blog-prose :global(h1[id]),
  .blog-prose :global(h2[id]),
  .blog-prose :global(h3[id]) {
    scroll-margin-top: 6rem;
  }

  @media (max-width: 720px) {
    h1 {
      font-size: clamp(2.2rem, 12vw, 3.1rem);
    }

    .post-hero-image {
      aspect-ratio: 2.45 / 1;
    }
  }
</style>
