---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { withBase } from "../../../lib/base";
---

<BaseLayout title="Reference | Sane C++ Libraries" description="Generated reference docs, compatibility routes, single-file tooling, and coverage artifacts.">
  <section class="shell page-hero">
    <div class="section-heading">
      <div class="eyebrow">Reference Layer</div>
      <h1>Reference and generated docs</h1>
      <p>
        Doxygen output remains available for API detail, snippets, graphs, coverage, and compatibility links.
      </p>
    </div>
    <div class="card-grid grid">
      <a class="card reference-card" href={withBase("/reference/doxygen/")}>
        <span class="material-symbols-outlined" aria-hidden="true">description</span>
        <div>
          <strong>Doxygen reference</strong>
          <p>Open the generated documentation subtree that is copied into the final Pages artifact.</p>
        </div>
      </a>
      <a class="card reference-card" href={withBase("/reference/doxygen/page_single_file_libs.html")}>
        <span class="material-symbols-outlined" aria-hidden="true">inventory_2</span>
        <div>
          <strong>Single-file library browser</strong>
          <p>Generate the standalone library headers used by the single-file integration path.</p>
        </div>
      </a>
      <a class="card reference-card" href={withBase("/reference/doxygen/coverage/")}>
        <span class="material-symbols-outlined" aria-hidden="true">monitoring</span>
        <div>
          <strong>Coverage reports</strong>
          <p>Coverage stays shipped alongside the generated docs after the existing CI steps run.</p>
        </div>
      </a>
      <a class="card reference-card" href={withBase("/libraries/")}>
        <span class="material-symbols-outlined" aria-hidden="true">account_tree</span>
        <div>
          <strong>Curated library pages</strong>
          <p>Start from the library boundary before diving into generated symbols.</p>
        </div>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .reference-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.95rem;
    align-items: start;
  }

  .reference-card .material-symbols-outlined {
    width: 2.25rem;
    height: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    color: var(--accent-cool);
    background: color-mix(in srgb, var(--accent-cool) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-cool) 22%, var(--border));
    font-size: 1.22rem;
  }

  .reference-card p {
    margin-top: 0.55rem;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
