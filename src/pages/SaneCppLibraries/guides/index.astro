---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getGuides } from "../../../lib/site-data";
import { withBase } from "../../../lib/base";

const guides = getGuides();
---

<BaseLayout title="Guides | Sane C++ Libraries" description="Practical guides for using, integrating, building, and contributing to Sane C++ Libraries.">
  <section class="shell page-hero">
    <div class="section-heading">
      <div class="eyebrow">Guides</div>
      <h1>Practical guides</h1>
      <p>These pages are sourced from the repo docs and organized around common tasks.</p>
    </div>
    <div class="card-grid grid">
      {guides.map((guide) => {
        const href = guide.slug === "single-file-libs"
          ? withBase("/reference/doxygen/page_single_file_libs.html")
          : withBase(`/guides/${guide.slug}/`);
        return (
          <a class="card guide-card" href={href}>
            <span class="material-symbols-outlined" aria-hidden="true">{guide.icon}</span>
            <div>
              <strong>{guide.title}</strong>
              <p>{guide.summary}</p>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style>
  .grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .guide-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.95rem;
    align-items: start;
  }

  .guide-card .material-symbols-outlined {
    width: 2.25rem;
    height: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    color: var(--accent-cool);
    background: color-mix(in srgb, var(--accent-cool) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-cool) 22%, var(--border));
    font-size: 1.22rem;
  }

  .guide-card strong,
  .guide-card p {
    display: block;
  }

  .guide-card p {
    margin-top: 0.55rem;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
