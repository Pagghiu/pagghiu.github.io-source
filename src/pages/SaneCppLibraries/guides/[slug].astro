---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getGuides, renderGuideMarkdown } from "../../../lib/site-data";
import { withBase } from "../../../lib/base";
import { decodeHTML } from "entities";

export function getStaticPaths() {
  return getGuides().map((guide) => ({ params: { slug: guide.slug }, props: { guide } }));
}

const { guide } = Astro.props;
let html = await renderGuideMarkdown(guide);
const tocItems: Array<{ level: number; id: string; label: string }> = [];
const usedHeadingIds = new Map<string, number>();
html = html.replace(/<h([1-3])>([\s\S]*?)<\/h\1>/g, (_match, levelText, contents) => {
  const label = decodeHTML(contents.replace(/<[^>]+>/g, "")).trim();
  const baseId = label.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "") || "section";
  const occurrence = usedHeadingIds.get(baseId) ?? 0;
  usedHeadingIds.set(baseId, occurrence + 1);
  const id = occurrence === 0 ? baseId : `${baseId}-${occurrence + 1}`;
  tocItems.push({ level: Number(levelText), id, label });
  return `<h${levelText} id="${id}">${contents}</h${levelText}>`;
});

const isPlatforms = guide.slug === "platforms";
const isTests = guide.slug === "tests";
const isSingleFile = guide.slug === "single-file-libs";
const tocBaseLevel = tocItems.length > 0 ? Math.min(...tocItems.map((item) => item.level)) : 1;
---

<BaseLayout title={`${guide.title} | Sane C++ Libraries`} description={guide.summary}>
  <section class="shell page-hero">
    <div class="section-heading">
      <div class="eyebrow">Guide</div>
      <h1>{guide.title}</h1>
      <p>{guide.summary}</p>
    </div>
  </section>
  <section class="shell page-grid">
    {isPlatforms ? (
      <article class="platform-guide">
        <section class="platform-band supported">
          <div class="platform-band-heading">
            <span class="material-symbols-outlined" aria-hidden="true">verified</span>
            <div><span>Supported</span><h2>Production targets</h2></div>
          </div>
          <div class="platform-cards">
            <div class="platform-card"><span class="material-symbols-outlined">laptop_mac</span><strong>Apple</strong><p>macOS 13.6+ and iOS 14.0+</p></div>
            <div class="platform-card"><span class="material-symbols-outlined">desktop_windows</span><strong>Windows</strong><p>Windows 10 and newer</p></div>
            <div class="platform-card"><span class="material-symbols-outlined">terminal</span><strong>Linux</strong><p>Linux kernel 5.x and newer</p></div>
          </div>
        </section>
        <section class="platform-band future">
          <div class="platform-band-heading"><span class="material-symbols-outlined">experiment</span><div><span>Planned</span><h2>WebAssembly</h2></div></div>
          <p>Emscripten and WASI are intended future targets, but are not part of the supported matrix today.</p>
        </section>
        <section class="platform-band excluded">
          <div class="platform-band-heading"><span class="material-symbols-outlined">block</span><div><span>Not planned</span><h2>Android</h2></div></div>
          <p>Android is not currently on the project roadmap.</p>
        </section>
      </article>
    ) : isSingleFile ? (
      <article class="panel action-guide">
        <span class="material-symbols-outlined" aria-hidden="true">inventory_2</span>
        <div>
          <h2>Generate a standalone header</h2>
          <p>The amalgamation tool is an interactive generated page. Open it to select a library, inspect its dependencies, and download the resulting single-file header.</p>
          <a class="button primary" href={withBase("/reference/doxygen/page_single_file_libs.html")}>Open amalgamation tool</a>
        </div>
      </article>
    ) : (
      <article class="panel prose article" set:html={html} />
    )}

    {isTests && (
      <section class="coverage-panel panel">
        <div class="coverage-heading">
          <div><span class="eyebrow">Live report</span><h2>Current test coverage</h2></div>
          <a class="button" href={withBase("/reference/doxygen/coverage/")}>Open full report</a>
        </div>
        <iframe title="Sane C++ Libraries test coverage" src="https://pagghiu.github.io/SaneCppLibraries/reference/doxygen/coverage/" loading="lazy"></iframe>
      </section>
    )}

    <aside class="sidebar">
      {tocItems.length > 1 && !isPlatforms && !isSingleFile && (
        <div class="card toc-card">
          <strong>On this page</strong>
          <nav aria-label="Page sections">
            {tocItems.map((item) => <a class:list={{ nested: item.level > tocBaseLevel }} href={`#${item.id}`}>{item.label}</a>)}
          </nav>
        </div>
      )}
      <div class="card">
        <strong>Reference fallback</strong>
        <a href={withBase(`/reference/doxygen/${guide.oldPath}`)}>Open legacy generated page</a>
      </div>
      <div class="card">
        <strong>Next places to look</strong>
        <a href={withBase("/libraries/")}>Library catalog</a>
        <a href={withBase("/reference/")}>Generated reference</a>
        <a href={withBase("/community/")}>Contributing and community</a>
      </div>
    </aside>
  </section>
</BaseLayout>

<style>
  .page-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.7fr);
    gap: 1.25rem;
    min-width: 0;
  }

  .article {
    min-width: 0;
    max-width: 100%;
    padding: 1.5rem;
    overflow: hidden;
  }

  .article :global(h1),
  .article :global(h2),
  .article :global(h3) {
    scroll-margin-top: calc(var(--nav-height) + 1rem);
  }

  .article :global(table) {
    overflow-x: auto;
  }

  .article :global(th),
  .article :global(td) {
    overflow-wrap: normal;
    word-break: normal;
  }

  .article :global(th:first-child),
  .article :global(td:first-child) {
    min-width: max-content;
    white-space: nowrap;
  }

  .sidebar {
    display: grid;
    gap: 1rem;
    align-self: start;
    position: sticky;
    top: calc(var(--nav-height) + 1rem);
    max-height: calc(100vh - var(--nav-height) - 2rem);
    overflow-y: auto;
    scrollbar-width: thin;
  }

  .sidebar .card {
    display: grid;
    gap: 0.75rem;
  }

  .sidebar a {
    color: var(--link);
    font-weight: 700;
  }

  .sidebar a:hover {
    color: var(--link-hover);
  }

  .toc-card nav {
    display: grid;
    gap: 0.45rem;
  }

  .toc-card nav a {
    color: var(--muted-strong);
    font-size: 0.88rem;
    line-height: 1.3;
  }

  .toc-card nav a.nested {
    padding-left: 0.85rem;
  }

  .platform-guide {
    display: grid;
    gap: 1rem;
  }

  .platform-band {
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-card);
  }

  .platform-band-heading {
    display: flex;
    gap: 0.9rem;
    align-items: center;
    margin-bottom: 1rem;
  }

  .platform-band-heading > .material-symbols-outlined {
    color: var(--accent-cool);
    font-size: 2rem;
  }

  .platform-band-heading span:not(.material-symbols-outlined) {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .platform-band h2,
  .action-guide h2,
  .coverage-heading h2 {
    margin: 0;
  }

  .platform-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .platform-card {
    display: grid;
    gap: 0.45rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface-soft);
  }

  .platform-card .material-symbols-outlined {
    color: var(--link);
  }

  .platform-card p,
  .platform-band > p,
  .action-guide p {
    margin: 0;
    color: var(--muted-strong);
  }

  .action-guide {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1rem;
    padding: 1.5rem;
    align-items: start;
  }

  .action-guide > .material-symbols-outlined {
    color: var(--link);
    font-size: 2rem;
  }

  .action-guide p {
    margin: 0.75rem 0 1.2rem;
  }

  .coverage-panel {
    grid-column: 1;
    padding: 1rem;
  }

  .coverage-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .coverage-panel iframe {
    width: 100%;
    min-height: 70vh;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: white;
  }

  @media (max-width: 960px) {
    .page-grid {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
      max-height: none;
      overflow: visible;
    }

    .platform-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
