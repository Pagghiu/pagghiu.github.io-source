---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getGuides, renderRepoMarkdown } from "../../../lib/site-data";
import { withBase } from "../../../lib/base";

export function getStaticPaths() {
  return getGuides().map((guide) => ({ params: { slug: guide.slug }, props: { guide } }));
}

const { guide } = Astro.props;
const html = await renderRepoMarkdown(guide.sourcePath, "guide");
---

<BaseLayout title={`${guide.title} | Sane C++ Libraries`} description={guide.summary}>
  <section class="shell page-hero">
    <div class="section-heading">
      <div class="eyebrow">Guide</div>
      <h1>{guide.title}</h1>
      <p>{guide.summary}</p>
    </div>
  </section>
  <section class="shell page-grid">
    <article class="panel prose article" set:html={html} />
    <aside class="sidebar">
      <div class="card">
        <strong>Reference fallback</strong>
        <a href={withBase(`/reference/doxygen/${guide.oldPath}`)}>Open legacy generated page</a>
      </div>
      <div class="card">
        <strong>Next places to look</strong>
        <a href={withBase("/libraries/")}>Library catalog</a>
        <a href={withBase("/reference/")}>Generated reference</a>
        <a href={withBase("/community/")}>Contributing and community</a>
      </div>
    </aside>
  </section>
</BaseLayout>

<style>
  .page-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.7fr);
    gap: 1.25rem;
  }

  .article {
    padding: 1.5rem;
  }

  .sidebar {
    display: grid;
    gap: 1rem;
    align-self: start;
  }

  .sidebar .card {
    display: grid;
    gap: 0.75rem;
  }

  .sidebar a {
    color: #ffd8a8;
  }

  @media (max-width: 960px) {
    .page-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

