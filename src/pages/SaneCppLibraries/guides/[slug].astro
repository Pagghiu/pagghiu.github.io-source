---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import GuideFlow from "../../../components/GuideFlow.astro";
import { getCoverageSummary, getGuides, renderGuideMarkdown } from "../../../lib/site-data";
import { withBase } from "../../../lib/base";
import { decodeHTML } from "entities";

export function getStaticPaths() {
  return getGuides().map((guide) => ({ params: { slug: guide.slug }, props: { guide } }));
}

const { guide } = Astro.props;
let html = await renderGuideMarkdown(guide);
const tocItems: Array<{ level: number; id: string; label: string }> = [];
const usedHeadingIds = new Map<string, number>();
html = html.replace(/<h([1-3])>([\s\S]*?)<\/h\1>/g, (_match, levelText, contents) => {
  const label = decodeHTML(contents.replace(/<[^>]+>/g, "")).trim();
  const baseId = label.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "") || "section";
  const occurrence = usedHeadingIds.get(baseId) ?? 0;
  usedHeadingIds.set(baseId, occurrence + 1);
  const id = occurrence === 0 ? baseId : `${baseId}-${occurrence + 1}`;
  tocItems.push({ level: Number(levelText), id, label });
  return `<h${levelText} id="${id}">${contents}</h${levelText}>`;
});

const isPlatforms = guide.slug === "platforms";
const isTests = guide.slug === "tests";
const coverageSummary = isTests ? getCoverageSummary() : null;
const guideFlows = {
  build: "build",
  "build-external": "build-external",
  package: "package",
  tools: "tools"
} as const;
const guideFlow = guideFlows[guide.slug as keyof typeof guideFlows];
const tocBaseLevel = tocItems.length > 0 ? Math.min(...tocItems.map((item) => item.level)) : 1;
---

<BaseLayout title={`${guide.title} | Sane C++ Libraries`} description={guide.summary}>
  <section class="shell page-hero">
    <div class="section-heading">
      <div class="eyebrow">Guide</div>
      <h1>{guide.title}</h1>
      <p>{guide.summary}</p>
    </div>
  </section>
  <section class="shell page-grid">
    <div class="guide-primary">
      {guideFlow && <GuideFlow variant={guideFlow} />}
      {isPlatforms ? (
        <article class="platform-guide">
          <section class="platform-band supported">
            <div class="platform-band-heading">
              <span class="material-symbols-outlined" aria-hidden="true">verified</span>
              <div><span>Supported</span><h2>Production targets</h2></div>
            </div>
            <div class="platform-cards">
              <div class="platform-card"><span class="material-symbols-outlined">laptop_mac</span><strong>Apple</strong><p>macOS 13.6+ and iOS 14.0+</p></div>
              <div class="platform-card"><span class="material-symbols-outlined">desktop_windows</span><strong>Windows</strong><p>Windows 10 and newer</p></div>
              <div class="platform-card"><span class="material-symbols-outlined">terminal</span><strong>Linux</strong><p>Linux kernel 5.x and newer</p></div>
            </div>
          </section>
          <section class="platform-band future">
            <div class="platform-band-heading"><span class="material-symbols-outlined">experiment</span><div><span>Planned</span><h2>WebAssembly</h2></div></div>
            <p>Emscripten and WASI are intended future targets, but are not part of the supported matrix today.</p>
          </section>
          <section class="platform-band excluded">
            <div class="platform-band-heading"><span class="material-symbols-outlined">block</span><div><span>Not planned</span><h2>Android</h2></div></div>
            <p>Android is not currently on the project roadmap.</p>
          </section>
        </article>
      ) : (
        <article class="panel prose article" set:html={html} />
      )}

      {isTests && (
        <section class="coverage-panel panel">
          <div class="coverage-heading">
            <div><span class="eyebrow">Generated on publish</span><h2>Current test coverage</h2></div>
            <a class="button" href={withBase("/reference/doxygen/coverage/")}>Open file report</a>
          </div>
          {coverageSummary ? (
            <>
              <div class="coverage-metrics">
                {coverageSummary.metrics.map((metric) => (
                  <div class:list={["coverage-metric", metric.tone]} style={`--coverage: ${metric.percentage}%`}>
                    <span>{metric.label}</span>
                    <strong>{metric.percentage.toFixed(2)}%</strong>
                    <small>{metric.covered.toLocaleString()} of {metric.total.toLocaleString()}</small>
                    <div class="coverage-bar" aria-label={`${metric.label}: ${metric.percentage.toFixed(2)} percent`}>
                      <span></span>
                    </div>
                  </div>
                ))}
              </div>
              <p class="coverage-created">Report generated {coverageSummary.created}.</p>
            </>
          ) : (
            <p class="coverage-unavailable">Coverage totals appear here in published builds. Generate local coverage to preview them before publication.</p>
          )}
        </section>
      )}
    </div>

    <aside class="sidebar">
      {tocItems.length > 1 && !isPlatforms && (
        <div class="card toc-card">
          <strong>On this page</strong>
          <nav aria-label="Page sections">
            {tocItems.map((item) => <a class:list={{ nested: item.level > tocBaseLevel }} href={`#${item.id}`}>{item.label}</a>)}
          </nav>
        </div>
      )}
      <div class="card">
        <strong>Reference fallback</strong>
        <a href={withBase(`/reference/doxygen/${guide.oldPath}`)}>Open legacy generated page</a>
      </div>
      <div class="card">
        <strong>Next places to look</strong>
        <a href={withBase("/libraries/")}>Library catalog</a>
        <a href={withBase("/reference/")}>Generated reference</a>
        <a href={withBase("/community/")}>Contributing and community</a>
      </div>
    </aside>
  </section>
</BaseLayout>

<style>
  .page-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.7fr);
    gap: 1.25rem;
    min-width: 0;
  }

  .guide-primary {
    display: grid;
    gap: 1rem;
    min-width: 0;
  }

  .article {
    min-width: 0;
    max-width: 100%;
    padding: 1.5rem;
    overflow: hidden;
  }

  .article :global(h1),
  .article :global(h2),
  .article :global(h3) {
    scroll-margin-top: calc(var(--nav-height) + 1rem);
  }

  .article :global(table) {
    overflow-x: auto;
  }

  .article :global(th),
  .article :global(td) {
    overflow-wrap: normal;
    word-break: normal;
  }

  .article :global(th:first-child),
  .article :global(td:first-child) {
    min-width: max-content;
    white-space: nowrap;
  }

  .sidebar {
    display: grid;
    gap: 1rem;
    align-self: start;
    position: sticky;
    top: calc(var(--nav-height) + 1rem);
    max-height: calc(100vh - var(--nav-height) - 2rem);
    overflow-y: auto;
    scrollbar-width: thin;
  }

  .sidebar .card {
    display: grid;
    gap: 0.75rem;
  }

  .sidebar a {
    color: var(--link);
    font-weight: 700;
  }

  .sidebar a:hover {
    color: var(--link-hover);
  }

  .toc-card nav {
    display: grid;
    gap: 0.45rem;
  }

  .toc-card nav a {
    color: var(--muted-strong);
    font-size: 0.88rem;
    line-height: 1.3;
  }

  .toc-card nav a.nested {
    padding-left: 0.85rem;
  }

  .platform-guide {
    display: grid;
    gap: 1rem;
  }

  .platform-band {
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-card);
  }

  .platform-band-heading {
    display: flex;
    gap: 0.9rem;
    align-items: center;
    margin-bottom: 1rem;
  }

  .platform-band-heading > .material-symbols-outlined {
    color: var(--accent-cool);
    font-size: 2rem;
  }

  .platform-band-heading span:not(.material-symbols-outlined) {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .platform-band h2,
  .coverage-heading h2 {
    margin: 0;
  }

  .platform-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .platform-card {
    display: grid;
    gap: 0.45rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface-soft);
  }

  .platform-card .material-symbols-outlined {
    color: var(--link);
  }

  .platform-card p,
  .platform-band > p {
    margin: 0;
    color: var(--muted-strong);
  }

  .coverage-panel {
    padding: 1.25rem;
  }

  .coverage-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .coverage-metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .coverage-metric {
    display: grid;
    gap: 0.3rem;
    padding: 0.9rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface-soft);
  }

  .coverage-metric > span,
  .coverage-metric small,
  .coverage-created,
  .coverage-unavailable {
    color: var(--muted);
  }

  .coverage-metric strong {
    font-size: 1.35rem;
  }

  .coverage-bar {
    height: 0.4rem;
    margin-top: 0.35rem;
    overflow: hidden;
    border-radius: 2px;
    background: color-mix(in srgb, var(--border-strong) 70%, transparent);
  }

  .coverage-bar span {
    display: block;
    width: var(--coverage);
    height: 100%;
    background: var(--coverage-color);
  }

  .coverage-metric.strong { --coverage-color: var(--success); }
  .coverage-metric.moderate { --coverage-color: #c58a00; }
  .coverage-metric.low { --coverage-color: #d24b55; }

  .coverage-created,
  .coverage-unavailable {
    margin: 0.9rem 0 0;
    font-size: 0.88rem;
  }

  @media (max-width: 960px) {
    .page-grid {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
      max-height: none;
      overflow: visible;
    }

    .platform-cards {
      grid-template-columns: 1fr;
    }

    .coverage-metrics {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    .coverage-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .coverage-metrics {
      grid-template-columns: 1fr;
    }
  }
</style>
