---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getSkills, getSkillStructure } from "../../../lib/site-data";

const [skill] = getSkills();
const structure = getSkillStructure();
const stats = [
  { label: "Installed skill", value: "1", hint: "One entry point for the whole repo" },
  { label: "Topic guides", value: String(structure?.guideCount ?? 0), hint: "Loaded only when the request needs them" },
  { label: "Reference files", value: String(structure?.referenceFileCount ?? 0), hint: "Extra detail behind the guides" }
];
---

<BaseLayout title="Skill | Sane C++ Libraries" description="The repo skill that helps agents discover the right Sane C++ topic before editing code.">
  <section class="shell page-hero skill-hero">
    <div class="section-heading">
      <div class="eyebrow">Repository skill</div>
      <h1>One skill, many small routes.</h1>
      <p>
        The Sane C++ skill is not a long catalog. It is an agent-facing map: start with the shared rules,
        choose the smallest matching topic, then inspect the actual headers, tests, examples, docs, or tools before
        editing code.
      </p>
    </div>

    <div class="skill-flow panel" aria-label="Skill discovery flow">
      <div class="flow-step">
        <span class="material-symbols-outlined" aria-hidden="true">chat</span>
        <strong>User request</strong>
        <p>Adopt, debug, extend, or review a Sane C++ library.</p>
      </div>
      <span class="flow-arrow material-symbols-outlined" aria-hidden="true">arrow_forward</span>
      <div class="flow-step active">
        <span class="material-symbols-outlined" aria-hidden="true">route</span>
        <strong>Skill router</strong>
        <p>Read <code>getting-started</code>, then select the relevant topic route.</p>
      </div>
      <span class="flow-arrow material-symbols-outlined" aria-hidden="true">arrow_forward</span>
      <div class="flow-step">
        <span class="material-symbols-outlined" aria-hidden="true">fact_check</span>
        <strong>Repo evidence</strong>
        <p>Ground the answer in source, tests, examples, and generated docs.</p>
      </div>
    </div>
  </section>

  <section class="shell skill-overview">
    <div class="stat-row">
      {stats.map((stat) => (
        <article class="stat-card">
          <strong>{stat.value}</strong>
          <span>{stat.label}</span>
          <p>{stat.hint}</p>
        </article>
      ))}
    </div>

    <div class="overview-grid">
      <article class="panel explanation-card">
        <span class="material-symbols-outlined" aria-hidden="true">filter_alt</span>
        <h2>Progressive disclosure</h2>
        <p>
          Agents should not load the whole repository manual for every request. The skill keeps context small by
          opening only the repo-wide rules, one primary topic guide, and at most a couple of companion guides.
        </p>
        <p>
          That makes the agent faster, but more importantly it keeps the active context relevant enough that it can
          stay under control.
        </p>
      </article>

      <article class="panel explanation-card">
        <span class="material-symbols-outlined" aria-hidden="true">grid_view</span>
        <h2>Orthogonal routes</h2>
        <p>
          Each route answers one kind of question: build setup, async I/O, containers, serialization, plugin loading,
          tests, examples, and so on. The guides overlap as little as practical, so an agent can find the right
          boundary without receiving generic C++ advice.
        </p>
        <a class="text-link" href={skill?.sourceUrl} target="_blank" rel="noreferrer">Open skill source</a>
      </article>
    </div>
  </section>

  <section class="shell structure-section">
    <div class="section-heading">
      <div class="eyebrow">Structure</div>
      <h2>How the skill is shaped</h2>
      <p>
        The root file is intentionally short. Deeper reference files sit behind topic guides and are pulled in only
        when the task needs that detail.
      </p>
    </div>

    <div class="structure-grid">
      <pre class="panel skill-tree"><code>{structure?.rootRelative ?? "Skills/sane-cpp-libraries"}
  SKILL.md
  agents/openai.yaml
  references/getting-started.md
  references/topic-map.md
  references/&lt;topic&gt;/guide.md
  references/&lt;topic&gt;/references/*.md</code></pre>

      <div class="principle-list">
        <article class="principle-item">
          <span class="material-symbols-outlined" aria-hidden="true">looks_one</span>
          <div>
            <strong>Start shared</strong>
            <p>Read the global repository rules before choosing a library-specific path.</p>
          </div>
        </article>
        <article class="principle-item">
          <span class="material-symbols-outlined" aria-hidden="true">looks_two</span>
          <div>
            <strong>Narrow quickly</strong>
            <p>Pick the smallest topic guide that matches the requested change.</p>
          </div>
        </article>
        <article class="principle-item">
          <span class="material-symbols-outlined" aria-hidden="true">looks_3</span>
          <div>
            <strong>Verify locally</strong>
            <p>Inspect headers, tests, examples, docs, or tools before producing a patch.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  {structure && (
    <section class="shell routes-section">
      <div class="section-heading">
        <div class="eyebrow">Topic routes</div>
        <h2>What the skill can route to</h2>
      </div>
      <div class="route-grid">
        {structure.groups.map((group) => (
          <article class="card route-card">
            <span class="material-symbols-outlined" aria-hidden="true">{group.icon}</span>
            <div>
              <h3>{group.title}</h3>
              <ul>
                {group.items.slice(0, 6).map((item) => <li>{item}</li>)}
              </ul>
              {group.items.length > 6 && <small>+ {group.items.length - 6} more routes</small>}
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  {skill && (
    <section class="shell source-strip">
      <a class="panel source-card" href={skill.sourceUrl} target="_blank" rel="noreferrer">
        <span class="material-symbols-outlined" aria-hidden="true">open_in_new</span>
        <div>
          <strong>{skill.title}</strong>
          <p>{skill.description}</p>
          <small>{skill.slug}</small>
        </div>
      </a>
    </section>
  )}
</BaseLayout>

<style>
  .skill-hero {
    padding-bottom: 1.5rem;
  }

  .skill-flow {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr) auto minmax(0, 1fr);
    gap: 1rem;
    align-items: stretch;
    padding: 1rem;
  }

  .flow-step {
    display: grid;
    gap: 0.55rem;
    align-content: start;
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-card) 88%, transparent);
  }

  .flow-step.active {
    border-color: color-mix(in srgb, var(--accent-cool) 44%, var(--border));
    background: color-mix(in srgb, var(--accent-cool) 10%, var(--bg-card));
  }

  .flow-step .material-symbols-outlined,
  .explanation-card > .material-symbols-outlined,
  .principle-item > .material-symbols-outlined,
  .route-card > .material-symbols-outlined,
  .source-card > .material-symbols-outlined {
    width: 2.35rem;
    height: 2.35rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    color: var(--accent-cool);
    background: color-mix(in srgb, var(--accent-cool) 11%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-cool) 28%, var(--border));
    font-size: 1.25rem;
  }

  .flow-step p,
  .explanation-card p,
  .principle-item p,
  .route-card li,
  .source-card p {
    color: var(--muted);
  }

  .flow-step p,
  .principle-item p,
  .source-card p {
    margin: 0;
  }

  .flow-step code {
    padding: 0.12rem 0.32rem;
    border-radius: 6px;
    background: color-mix(in srgb, var(--surface-strong) 78%, transparent);
    color: var(--muted-strong);
    font-size: 0.92em;
  }

  .flow-arrow {
    align-self: center;
    color: var(--muted);
  }

  .skill-overview,
  .structure-section,
  .routes-section,
  .source-strip {
    margin-top: 1.2rem;
  }

  .stat-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .stat-card {
    padding: 1.15rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-card) 90%, transparent);
  }

  .stat-card strong {
    display: block;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1;
  }

  .stat-card span {
    display: block;
    margin-top: 0.55rem;
    font-weight: 800;
  }

  .stat-card p {
    margin: 0.35rem 0 0;
    color: var(--muted);
  }

  .overview-grid,
  .structure-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .explanation-card {
    padding: 1.25rem;
  }

  .explanation-card h2 {
    margin: 1rem 0 0.7rem;
    font-size: clamp(1.45rem, 2vw, 2rem);
  }

  .skill-tree {
    margin: 0;
    white-space: pre-wrap;
    color: var(--muted-strong);
    line-height: 1.75;
  }

  .principle-list {
    display: grid;
    gap: 1rem;
  }

  .principle-item,
  .source-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.9rem;
    align-items: start;
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-card) 90%, transparent);
  }

  .route-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .route-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.95rem;
  }

  .route-card h3 {
    margin: 0 0 0.7rem;
  }

  .route-card ul {
    margin: 0;
    padding-left: 1.15rem;
  }

  .route-card small,
  .source-card small {
    display: block;
    margin-top: 0.7rem;
    color: var(--muted);
  }

  .source-card {
    color: inherit;
  }

  @media (max-width: 900px) {
    .skill-flow,
    .stat-row,
    .overview-grid,
    .structure-grid,
    .route-grid {
      grid-template-columns: 1fr;
    }

    .flow-arrow {
      display: none;
    }
  }
</style>
