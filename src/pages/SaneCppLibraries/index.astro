---
import BaseLayout from "../../layouts/BaseLayout.astro";
import InstallTabs from "../../components/InstallTabs.astro";
import LibraryIcon from "../../components/LibraryIcon.astro";
import MaturityBadge from "../../components/MaturityBadge.astro";
import { getFeaturedLibraries, getHomeMetrics, getLibraries, getSkills } from "../../lib/site-data";
import { withBase } from "../../lib/base";

const metrics = getHomeMetrics();
const libraries = getLibraries();
const featuredLibraries = getFeaturedLibraries();
const [skill] = getSkills();
const heroLibraries = libraries.map((library) => ({ slug: library.slug, title: library.title }));

const constraints = ["Agent-first", "Ready-to-use skills", "Use what you need", "No hidden allocations", "Not a framework"];
const agentBrief = `Title: HttpClient: Add a request timeout option
Objective: fail requests that take too long
Context: fit the existing streaming-first design
Constraints: no hidden allocations, preserve platform backends
Validation: run the focused HttpClient tests in Debug`;
---

<BaseLayout
  title="Sane C++ Libraries"
  description="Cross-platform C++ libraries maintained through issues, Prompt Requests, repo skills, and agent replay."
>
  <section class="agent-hero">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <h1>Sane C++ Libraries</h1>
        <p class="hero-lede">
          Cross-platform C++ libraries built for agents.
        </p>
        <div class="constraint-rail" aria-label="Core constraints">
          {constraints.map((constraint) => <span>{constraint}</span>)}
        </div>
        <div class="hero-actions">
          <a class="button primary" href={withBase("/guides/building-user/")}>
            <span class="material-symbols-outlined" aria-hidden="true">rocket_launch</span>
            Get started
          </a>
          <a class="button" href={withBase("/libraries/")}>
            <span class="material-symbols-outlined" aria-hidden="true">account_tree</span>
            Library map
          </a>
        </div>
      </div>

      <figure class="hero-visual">
        <img src={withBase("/brand/agent-runtime-map.png")} alt="Library and platform map for Sane C++ Libraries" />
        <aside class="hero-library-panel" aria-label="Sane C++ Libraries">
          <strong>Libraries</strong>
          <ul>
            {heroLibraries.map((library) => (
              <li>
                <a href={withBase(`/libraries/${library.slug}/`)}>{library.title}</a>
              </li>
            ))}
          </ul>
        </aside>
        <figcaption>
          <strong>Cross-platform</strong>
          <span>Targets macOS, Windows, and Linux on x86_64 and ARM64.</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="shell metric-band" aria-label="Project snapshot">
    {metrics.map((metric) => (
      <article class="metric">
        <strong>{metric.value}</strong>
        <span>{metric.label}</span>
        <small>{metric.hint}</small>
      </article>
    ))}
  </section>

  <section class="shell dependency-map-section panel">
    <div class="dependency-map-copy">
      <div class="eyebrow">Dependency map</div>
      <h2>Library graph</h2>
      <p>
        Most libraries have no library-level dependency. A few higher-level libraries build on those small
        pillars, so you can pick one useful piece without switching your whole project to Sane C++.
      </p>
    </div>
    <div class="dependency-map-frame">
      <img src="/images/dependencies/SaneCppLibrariesDependencies.svg" alt="Dependency map for Sane C++ Libraries" loading="lazy" />
    </div>
  </section>

  <section class="shell section operating-model">
    <div class="section-heading">
      <div class="eyebrow">The reasons</div>
      <h2>Why this shape?</h2>
      <p>
        Sane C++ Libraries tries to blend the compactness of single-file libraries with the convenience of a
        small runtime. You can start with one library, a unity-build checkout, or the full SC::Build workflow
        without turning your project into a framework.
      </p>
    </div>
    <div class="model-grid">
      <article class="model-card">
        <span class="material-symbols-outlined" aria-hidden="true">rule</span>
        <h3>Independent libraries</h3>
        <p>A small amount of code duplication is accepted in order to keep many libraries isolated.</p>
      </article>
      <article class="model-card">
        <span class="material-symbols-outlined" aria-hidden="true">schema</span>
        <h3>Working like a runtime</h3>
        <p>It brings ready-to-use runtime pieces that C++ projects often miss, closer to what developers expect from JavaScript or Python.</p>
      </article>
      <article class="model-card">
        <span class="material-symbols-outlined" aria-hidden="true">task_alt</span>
        <h3>Composable by design</h3>
        <p>Libraries stay useful on their own, but their explicit boundaries make them easy to combine when a project grows.</p>
      </article>
    </div>
  </section>

  <section class="shell section workbench-section">
    <div class="agent-brief panel">
      <div class="section-heading compact">
        <div class="eyebrow">Contributions</div>
        <h2>PR means Prompt Request</h2>
        <p>
          The maintainer should be able to recreate or adapt the work from a clean checkout. The prompt is evaluated as
          durable context, not as a demand for byte-identical code.
        </p>
      </div>
      <pre><code>{agentBrief}</code></pre>
      {skill && (
        <a class="text-link" href={withBase("/skills/")}>
          Open the repository skill
          <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
        </a>
      )}
    </div>

    <aside class="adoption-panel panel">
      <div class="section-heading compact">
        <div class="eyebrow">Investment level</div>
        <h2>Small, medium or big</h2>
      </div>
      <InstallTabs />
    </aside>
  </section>

  <section class="shell section library-map-section">
    <div class="section-heading heading-with-link">
      <div>
        <div class="eyebrow">Libraries</div>
        <h2>Not a framework</h2>
        <p>The project is not a framework. The libraries try to stay as independent as possible, even at the cost of some internal duplication, while still working smoothly together. You can use one or two of them without pulling in the whole codebase.</p>
      </div>
      <a class="button" href={withBase("/libraries/")}>
        <span class="material-symbols-outlined" aria-hidden="true">table_rows</span>
        Full catalog
      </a>
    </div>
    <div class="featured-libraries">
      {featuredLibraries.map((library) => (
        <a class="library-tile" href={withBase(`/libraries/${library.slug}/`)}>
          <LibraryIcon slug={library.slug} />
          <div>
            <strong>{library.title}</strong>
            <span>{library.summary}</span>
          </div>
          <MaturityBadge label={library.maturityLabel} tone={library.maturityTone} />
        </a>
      ))}
    </div>
  </section>

  <section class="shell section">
    <div class="section-heading">
      <div class="eyebrow">Catalog</div>
      <h2>Full list</h2>
      <p>Use the catalog to pick the smallest useful building block for your project or Prompt Request.</p>
    </div>
    <div class="library-table panel">
      <div class="library-table-head">
        <div>Library</div>
        <div>Status / Description</div>
        <div>Download</div>
      </div>
      {libraries.map((library) => (
        <a class="library-row" href={withBase(`/libraries/${library.slug}/`)}>
          <div class="library-name">
            <LibraryIcon slug={library.slug} size="sm" />
            <strong>{library.title}</strong>
          </div>
          <div class="library-status">
            <MaturityBadge label={library.maturityLabel} tone={library.maturityTone} variant="strong" />
            <span>{library.summary}</span>
          </div>
          <div class="library-download">
            <span>{library.singleFileDownload ? library.singleFileDownload.split("/").pop() : "In repo"}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .agent-hero {
    min-height: calc(100vh - var(--nav-height));
    display: grid;
    align-items: center;
    padding: 2.2rem 0 3rem;
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
    gap: 2rem;
    align-items: center;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
  }

  .hero-copy h1 {
    margin: 0 0 1.2rem;
    font-size: clamp(3.1rem, 7vw, 6.4rem);
    line-height: 0.95;
    letter-spacing: 0;
    max-width: 9ch;
  }

  .hero-lede {
    margin: 0;
    color: var(--muted-strong);
    font-size: clamp(1.05rem, 1.7vw, 1.32rem);
    line-height: 1.65;
    max-width: 46rem;
  }

  .constraint-rail {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 1.6rem 0 1.8rem;
  }

  .constraint-rail span {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem 0.65rem;
    color: var(--muted-strong);
    background: color-mix(in srgb, var(--surface-strong) 65%, transparent);
    font-size: 0.83rem;
    font-weight: 750;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .hero-actions .material-symbols-outlined,
  .heading-with-link .material-symbols-outlined,
  .text-link .material-symbols-outlined {
    font-size: 1.1rem;
  }

  .hero-visual {
    position: relative;
    margin: 0;
    min-width: 0;
    overflow: hidden;
    border-radius: 8px;
    background: #08111e;
    box-shadow: 0 26px 90px rgba(0, 0, 0, 0.42);
  }

  .hero-visual::before {
    content: "";
    position: absolute;
    inset: 10% -10% -5% 22%;
    border-radius: 50%;
    background: color-mix(in srgb, var(--accent-strong) 18%, transparent);
    filter: blur(72px);
    z-index: -1;
  }

  .hero-visual img {
    width: 100%;
    max-width: 100%;
    height: auto;
    margin: 0;
    border-radius: 8px;
  }

  .hero-library-panel {
    position: absolute;
    left: 0.8rem;
    top: 0.8rem;
    width: min(23rem, 48%);
    max-height: calc(100% - 1.6rem);
    overflow: hidden;
    padding: 0.95rem;
    border-radius: 8px;
    border: 1px solid rgba(105, 214, 255, 0.2);
    color: #f4f7fb;
    background: rgba(8, 17, 30, 0.78);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(18px);
  }

  .hero-library-panel strong {
    display: block;
    margin-bottom: 0.55rem;
    font-size: 0.96rem;
  }

  .hero-library-panel ul {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: 0.8rem;
    row-gap: 0.12rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hero-library-panel li {
    min-width: 0;
  }

  .hero-library-panel a {
    display: block;
    padding: 0.1rem 0;
    color: rgba(231, 241, 255, 0.84);
    font-size: 0.68rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .hero-library-panel a:hover {
    color: var(--link-hover);
  }

  .hero-visual figcaption {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    width: min(26rem, calc(100% - 2rem));
    padding: 0.95rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-card) 82%, transparent);
    backdrop-filter: blur(18px);
  }

  .hero-visual figcaption strong,
  .hero-visual figcaption span {
    display: block;
  }

  .hero-visual figcaption span {
    margin-top: 0.25rem;
    color: var(--muted);
    line-height: 1.45;
  }

  .metric-band {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: -1.2rem;
  }

  .metric {
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface-strong) 64%, transparent);
  }

  .metric strong,
  .metric span,
  .metric small {
    display: block;
  }

  .metric strong {
    font-size: 1.55rem;
  }

  .metric small {
    color: var(--muted);
    margin-top: 0.28rem;
  }

  .section {
    margin-top: 5rem;
  }

  .model-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .model-card {
    padding: 1.3rem;
    border-radius: 8px;
    background: color-mix(in srgb, var(--surface-strong) 62%, transparent);
    border: 1px solid var(--border);
  }

  .model-card .material-symbols-outlined {
    color: var(--accent-cool);
    font-size: 1.7rem;
  }

  .model-card h3 {
    margin: 1rem 0 0.55rem;
    font-size: 1.15rem;
  }

  .model-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .workbench-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(340px, 0.82fr);
    gap: 1rem;
  }

  .agent-brief,
  .adoption-panel {
    min-width: 0;
    padding: 1.25rem;
  }

  .compact {
    margin-bottom: 1rem;
  }

  .compact h2 {
    font-size: clamp(1.6rem, 2.6vw, 2.35rem);
  }

  .agent-brief pre {
    margin: 1rem 0;
    font-size: 0.93rem;
    line-height: 1.65;
  }

  .text-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--link-hover);
    font-weight: 750;
  }

  .heading-with-link {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
  }

  .featured-libraries {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .dependency-map-section {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
    padding: 1rem;
  }

  .dependency-map-copy h2 {
    margin: 0.35rem 0 0;
    font-size: clamp(1.55rem, 3vw, 2.4rem);
    line-height: 1.12;
  }

  .dependency-map-copy p {
    margin: 0.8rem 0 0;
    max-width: 62rem;
    color: var(--muted-strong);
    line-height: 1.65;
  }

  .dependency-map-frame {
    overflow: auto;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: #fff;
    max-width: 100%;
  }

  .dependency-map-frame img {
    width: 100%;
    height: auto;
    min-width: 0;
  }

  .library-tile {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.9rem;
    align-items: start;
    min-height: 10rem;
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: linear-gradient(180deg, color-mix(in srgb, var(--surface-strong) 78%, transparent), var(--bg-card));
  }

  .library-tile strong,
  .library-tile span {
    display: block;
  }

  .library-tile > .maturity-badge {
    grid-column: 2;
    justify-self: start;
    align-self: end;
  }

  .library-tile div span {
    margin-top: 0.45rem;
    color: var(--muted);
    line-height: 1.55;
  }

  .library-table {
    overflow: hidden;
  }

  .library-table-head,
  .library-row {
    display: grid;
    grid-template-columns: minmax(220px, 1.1fr) minmax(0, 2.4fr) minmax(170px, 0.9fr);
    gap: 1rem;
    align-items: center;
    padding: 0.95rem 1rem;
  }

  .library-table-head {
    border-bottom: 1px solid var(--border);
    color: var(--muted-strong);
    text-transform: uppercase;
    letter-spacing: 0;
    font-size: 0.76rem;
    font-weight: 850;
  }

  .library-row {
    border-bottom: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    transition: background 160ms ease;
  }

  .library-row:last-child {
    border-bottom: 0;
  }

  .library-row:hover {
    background: color-mix(in srgb, var(--accent) 7%, transparent);
  }

  .library-name {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .library-name strong {
    font-size: 1.02rem;
  }

  .library-status {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .library-status span {
    color: var(--muted);
    line-height: 1.55;
  }

  .library-download {
    display: flex;
    justify-content: flex-end;
  }

  .library-download span {
    color: var(--link);
    font-size: 0.84rem;
    font-weight: 750;
  }

  @media (max-width: 1100px) {
    .agent-hero {
      min-height: auto;
      padding-top: 2rem;
    }

    .hero-grid,
    .workbench-section,
    .model-grid,
    .featured-libraries {
      grid-template-columns: 1fr;
    }

    .hero-copy h1 {
      max-width: none;
    }

    .hero-visual img {
      width: 100%;
      margin-left: 0;
    }

    .hero-library-panel {
      width: min(22rem, 48%);
    }

    .metric-band {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-top: 1rem;
    }

    .heading-with-link {
      align-items: start;
      flex-direction: column;
    }
  }

  @media (max-width: 720px) {
    .hero-copy h1 {
      font-size: clamp(3rem, 15vw, 4.3rem);
    }

    .hero-visual figcaption {
      position: static;
      width: auto;
      margin-top: 0.6rem;
    }

    .hero-library-panel {
      position: static;
      width: auto;
      max-height: none;
      overflow: visible;
      margin-top: 0.6rem;
    }

    .hero-library-panel ul {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 0.8rem;
    }

    .metric-band {
      grid-template-columns: 1fr;
    }

    .library-table-head {
      display: none;
    }

    .library-row {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .library-status {
      flex-direction: column;
      align-items: start;
    }

    .library-download {
      justify-content: start;
    }
  }
</style>
