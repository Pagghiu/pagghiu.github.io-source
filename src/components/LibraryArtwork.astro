---
interface Props {
  slug: string;
  title: string;
}

const { slug, title } = Astro.props;
const label = title.replace(/^SC::/, "");
---

<div class="library-art" role="img" aria-label={`${title} library cover`} data-library={slug}>
  <div class="logo-shell">
    <img src="/SaneCppLibraries/brand/sc-logo.svg" alt="" loading="lazy" />
  </div>
  <small>{label}</small>
</div>

<style>
  .library-art {
    width: 100%;
    max-width: 9rem;
    aspect-ratio: 1;
    display: grid;
    align-content: space-between;
    padding: 0.9rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background:
      radial-gradient(circle at top left, color-mix(in srgb, var(--accent-cool) 24%, transparent), transparent 58%),
      radial-gradient(circle at bottom right, color-mix(in srgb, var(--accent) 22%, transparent), transparent 64%),
      linear-gradient(180deg, color-mix(in srgb, var(--surface-strong) 90%, white 10%), var(--surface));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .logo-shell {
    display: grid;
    place-items: center;
    min-height: 6rem;
    border-radius: 8px;
    background: color-mix(in srgb, var(--surface) 82%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-cool) 16%, var(--border));
  }

  .logo-shell img {
    width: 4rem;
    height: 4rem;
    object-fit: contain;
    filter: drop-shadow(0 12px 24px rgba(0, 0, 0, 0.18));
  }

  .library-art small {
    display: inline-flex;
    align-items: center;
    min-height: 2.1rem;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted-strong);
  }
</style>
