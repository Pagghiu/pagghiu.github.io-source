---
const tabs = [
  {
    id: "single-file",
    label: "Small",
    copy: "Download one released standalone header when your program needs a single library.",
    code: `#include "SaneCppFoundation.h"`
  },
  {
    id: "repo-checkout",
    label: "Medium",
    copy: "Add the unity build when several libraries need to work together.",
    code: `Sources/
├── SC.cpp
└── YourApplication.cpp

Include path: SaneCppLibraries/Includes`
  },
  {
    id: "build-integration",
    label: "Big",
    copy: "Compile selected library sources separately when your build needs finer-grained targets and incremental work.",
    code: `Includes/                 # public API
Libraries/Foundation/    # selected sources
Libraries/Strings/       # selected sources`
  }
];
---

<div class="install-tabs" role="tablist" aria-label="Integration sizes">
  {tabs.map((tab, index) => (
    <button
      class={`install-tab ${index === 0 ? "active" : ""}`}
      type="button"
      role="tab"
      aria-selected={index === 0 ? "true" : "false"}
      data-install-tab={tab.id}
    >
      {tab.label}
    </button>
  ))}
</div>

<div class="install-panels">
  {tabs.map((tab, index) => (
    <section class={`install-panel ${index === 0 ? "active" : ""}`} data-install-panel={tab.id}>
      <p class="copy-muted">{tab.copy}</p>
      <pre><code>{tab.code}</code></pre>
    </section>
  ))}
</div>

<script is:inline>
  const tabs = Array.from(document.querySelectorAll("[data-install-tab]"));
  const panels = Array.from(document.querySelectorAll("[data-install-panel]"));

  function activateInstallTab(id) {
    tabs.forEach((tab) => {
      const isActive = tab.dataset.installTab === id;
      tab.classList.toggle("active", isActive);
      tab.setAttribute("aria-selected", isActive ? "true" : "false");
    });
    panels.forEach((panel) => {
      panel.classList.toggle("active", panel.dataset.installPanel === id);
    });
  }

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => activateInstallTab(tab.dataset.installTab));
  });
</script>

<style>
  .install-tabs {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin: 1rem 0 0.6rem;
  }

  .install-tab {
    border-radius: 8px;
    padding: 0.55rem 0.9rem;
    background: rgba(255, 255, 255, 0.03);
    color: var(--muted);
    border: 1px solid var(--border);
  }

  .install-tab.active {
    color: var(--text);
    background: rgba(120, 218, 255, 0.12);
    border-color: rgba(120, 218, 255, 0.3);
  }

  .install-panel {
    display: none;
  }

  .install-panel.active {
    display: block;
  }
</style>
