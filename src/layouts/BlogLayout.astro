---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import type { BlogPost, TocEntry } from "../lib/blog-data";

interface Props {
  title: string;
  description?: string;
  posts?: BlogPost[];
  activeSlug?: string;
  toc?: TocEntry[];
}

const { title, description = "Sane Coding Blog", posts = [], activeSlug, toc = [] } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const hasBlogSidebar = posts.length > 0;
const hasToc = toc.length > 0;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical.toString()} />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="alternate" type="application/atom+xml" title="Sane Coding Blog" href="/feeds/all.atom.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;650;750;850&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
    <script>
      (() => {
        const savedTheme = localStorage.getItem("sc-theme");
        const theme = savedTheme === "light" || savedTheme === "dark"
          ? savedTheme
          : (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body class="blog-body">
    <header class="blog-header">
      <div class="shell blog-nav">
        <a class="blog-brand" href="/">
          <img src="/images/favicon.png" alt="" width="46" height="46" />
          <strong>Sane Coding Blog</strong>
          <span>Notes on Sane C++ Libraries and practical systems work.</span>
        </a>
        <div class="blog-actions">
          <nav aria-label="Primary">
            <a href="/">Blog</a>
            <a href="/SaneCppLibraries/">Sane C++ Libraries</a>
            <a href="https://github.com/Pagghiu">GitHub</a>
          </nav>
          <ThemeToggle />
        </div>
      </div>
    </header>
    <main class:list={["blog-main", { "has-blog-sidebar": hasBlogSidebar, "has-toc": hasToc }]}>
      <div class="blog-frame">
        {hasBlogSidebar && (
          <aside class="blog-sidebar" aria-label="Blog navigation">
            <nav>
              <strong>Projects</strong>
              <a class="sidebar-link project-link" href="/SaneCppLibraries/">Sane C++ Libraries</a>
              <strong>Blog</strong>
              {posts.map((post) => (
                <a class:list={["sidebar-link", { active: post.slug === activeSlug }]} href={`/site/blog/${post.slug}.html`}>
                  {post.title}
                </a>
              ))}
            </nav>
          </aside>
        )}
        <div class="blog-content">
          <slot />
        </div>
        {hasToc && (
          <aside class="blog-toc" aria-label="Article sections">
            <strong>Content</strong>
            <nav>
              {toc.map((entry) => (
                <a href={entry.href}>{entry.label}</a>
              ))}
            </nav>
          </aside>
        )}
      </div>
    </main>
    <footer class="blog-footer">
      <div class="shell">
        <span>© Stefano Cristiano</span>
        <a href="/feeds/all.atom.xml">Atom feed</a>
      </div>
    </footer>
  </body>
</html>

<style>
  :global(.blog-body) {
    color: var(--text);
    background: var(--bg);
    overflow-x: clip;
  }

  :global(.blog-body)::before {
    display: none;
  }

  .blog-header {
    border-bottom: 1px solid var(--header-border);
    background: var(--header-bg);
    backdrop-filter: blur(18px);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .blog-nav {
    min-height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.4rem;
  }

  .blog-brand {
    display: grid;
    grid-template-columns: 46px minmax(0, 1fr);
    align-items: center;
    column-gap: 0.9rem;
  }

  .blog-brand img {
    grid-row: 1 / span 2;
    border-radius: 0;
  }

  .blog-brand strong,
  .blog-brand span {
    display: block;
  }

  .blog-brand strong {
    font-size: 1.05rem;
  }

  .blog-brand span {
    color: var(--muted);
    font-size: 0.9rem;
    margin-top: 0.12rem;
  }

  .blog-main {
    padding-top: 2rem;
  }

  .blog-frame {
    width: min(calc(100% - 2rem), 1440px);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(13rem, 16rem) minmax(0, 820px);
    justify-content: center;
    gap: 2.2rem;
  }

  .blog-main.has-toc .blog-frame {
    grid-template-columns: minmax(13rem, 16rem) minmax(0, 820px) minmax(12rem, 15rem);
  }

  .blog-main:not(.has-blog-sidebar) .blog-frame {
    grid-template-columns: minmax(0, 900px);
  }

  .blog-content {
    min-width: 0;
  }

  .blog-sidebar,
  .blog-toc {
    position: sticky;
    top: calc(64px + 2rem);
    align-self: start;
    max-height: calc(100vh - 6rem);
    overflow: auto;
    color: var(--muted);
  }

  .blog-sidebar nav,
  .blog-toc nav {
    display: grid;
    gap: 0.25rem;
  }

  .blog-sidebar strong,
  .blog-toc strong {
    display: block;
    margin: 0 0 0.65rem;
    color: var(--muted-strong);
    font-size: 0.9rem;
  }

  .blog-sidebar strong:not(:first-child) {
    margin-top: 1.6rem;
  }

  .sidebar-link,
  .blog-toc a {
    border-left: 2px solid transparent;
    padding: 0.36rem 0 0.36rem 0.9rem;
    color: var(--muted);
    line-height: 1.35;
    font-weight: 650;
  }

  .sidebar-link:hover,
  .sidebar-link.active,
  .blog-toc a:hover {
    border-left-color: var(--link);
    color: var(--link);
  }

  .project-link {
    margin-bottom: 0.35rem;
  }

  .blog-actions,
  .blog-nav nav {
    display: flex;
    align-items: center;
  }

  .blog-actions {
    gap: 0.75rem;
  }

  .blog-nav nav {
    gap: 1rem;
    font-weight: 750;
    color: var(--muted-strong);
  }

  .blog-footer {
    margin-top: 4rem;
    border-top: 1px solid var(--border);
    padding: 2rem 0;
    color: var(--muted);
  }

  .blog-footer .shell {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  @media (max-width: 720px) {
    .blog-main {
      padding-top: 1.4rem;
    }

    .blog-frame,
    .blog-main.has-toc .blog-frame {
      grid-template-columns: 1fr;
    }

    .blog-sidebar,
    .blog-toc {
      display: none;
    }

    .blog-nav,
    .blog-actions,
    .blog-footer .shell {
      align-items: flex-start;
      flex-direction: column;
    }

    .blog-nav nav {
      flex-wrap: wrap;
    }

    .blog-brand {
      grid-template-columns: minmax(0, 1fr);
    }

    .blog-brand img {
      display: none;
    }
  }
</style>
